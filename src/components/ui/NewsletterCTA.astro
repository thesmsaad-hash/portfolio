---
// src/components/ui/NewsletterCTA.astro
---
<section class="py-16 md:py-24 relative overflow-hidden" data-animate>
  <!-- Background Elements -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-brand-900/5 dark:bg-brand-900/10"></div>
    <div class="glow-orb w-[40rem] h-[40rem] bg-brand-500/20 -top-40 -right-20"></div>
    <div class="glow-orb w-[30rem] h-[30rem] bg-accent-500/20 -bottom-20 -left-10"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="max-w-5xl mx-auto">
      <div class="glass glass-card rounded-3xl p-8 md:p-12 lg:p-16 border border-white/10 dark:border-white/5 relative overflow-hidden shadow-2xl">
        
        <!-- Inner glow -->
        <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent opacity-50"></div>

        <div class="relative z-10 flex flex-col lg:flex-row gap-12 items-center text-center lg:text-left">
          
          <div class="flex-1 space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-500 text-sm font-medium">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
              </span>
              Stay Updated
            </div>
            
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-gray-900 dark:text-white leading-tight">
              Join the <span class="gradient-text">Newsletter</span>
            </h2>
            
            <p class="text-lg text-gray-600 dark:text-gray-300">
              Get actionable insights delivered straight to your inbox. This helps bring visitors back to your site.
            </p>

            <ul class="flex flex-col gap-3 text-left mt-6 max-w-sm mx-auto lg:mx-0">
              {[
                "New blog posts",
                "Editing tips",
                "AI tool recommendations",
                "Portfolio updates"
              ].map((item) => (
                <li class="flex items-center gap-3">
                  <div class="w-6 h-6 rounded-full bg-green-500/10 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-gray-700 dark:text-gray-300 font-medium">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="w-full max-w-md">
            <div id="newsletter-form-container" class="bg-white dark:bg-surface-dark-secondary rounded-2xl p-6 md:p-8 shadow-xl border border-gray-100 dark:border-gray-800">
              <form id="newsletter-form" action="https://assets.mailerlite.com/jsonp/2483736/forms/191812482725053719/subscribe" method="POST">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 text-center lg:text-left">Subscribe Now</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 text-center lg:text-left">No spam, unsubscribe anytime.</p>
                
                <div class="space-y-4">
                  <div>
                    <label for="newsletter-name" class="sr-only">First Name</label>
                    <input 
                      type="text" 
                      id="newsletter-name"
                      name="fields[name]" 
                      placeholder="First Name (Optional)" 
                      class="w-full px-4 py-3.5 bg-gray-50 dark:bg-surface-dark border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all text-gray-900 dark:text-white placeholder-gray-400"
                    />
                  </div>
                  <div>
                    <label for="newsletter-email" class="sr-only">Email Address</label>
                    <input 
                      type="email" 
                      id="newsletter-email"
                      name="fields[email]" 
                      placeholder="Email Address" 
                      required
                      class="w-full px-4 py-3.5 bg-gray-50 dark:bg-surface-dark border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all text-gray-900 dark:text-white placeholder-gray-400"
                    />
                  </div>
                  
                  <!-- MailerLite hidden fields -->
                  <input type="hidden" name="ml-submit" value="1">
                  <input type="hidden" name="anticsrf" value="true">
                  
                  <button type="submit" class="w-full btn-primary py-4 group relative overflow-hidden rounded-xl text-base font-bold mt-2">
                    <span class="relative z-10 flex items-center justify-center gap-2">
                      <span id="newsletter-btn-text">Subscribe</span>
                      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </span>
                  </button>
                </div>
              </form>
            </div>

            <!-- Success Message (Hidden by default) -->
            <div id="newsletter-success" class="hidden bg-white dark:bg-surface-dark-secondary rounded-2xl p-8 shadow-xl border border-green-500/20 text-center">
              <div class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">You're in!</h3>
              <p class="text-gray-500 dark:text-gray-400">Thanks for subscribing. Check your inbox soon!</p>
            </div>
          </div>
          
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MailerLite Scripts -->
<script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" type="text/javascript"></script>
<script is:inline>
  fetch("https://assets.mailerlite.com/jsonp/2483736/forms/191812482725053719/takel").catch(() => {});
</script>

<script>
  const form = document.getElementById('newsletter-form');
  const successMsg = document.getElementById('newsletter-success');
  const formContainer = document.getElementById('newsletter-form-container');
  const btnText = document.getElementById('newsletter-btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (btnText) btnText.innerHTML = 'Subscribing...';
    
    try {
      await fetch(form.action, {
        method: 'POST',
        body: new FormData(form as HTMLFormElement),
        headers: {
          'Accept': 'application/json'
        }
      });
      // Show success
      if (formContainer) formContainer.style.display = 'none';
      if (successMsg) successMsg.classList.remove('hidden');
    } catch (err) {
      if (btnText) btnText.innerHTML = 'Subscribe';
      // MailerLite might throw CORS error on success depending on browser setup, so we still show success if it fails but request went out.
      if (formContainer) formContainer.style.display = 'none';
      if (successMsg) successMsg.classList.remove('hidden');
    }
  });
</script>
