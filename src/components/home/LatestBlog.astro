---
import { getCollection } from 'astro:content';
import { formatDate, estimateReadingTime } from '../../utils/seo';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const latest = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="section bg-gray-50 dark:bg-surface-dark-secondary">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12" data-animate>
      <div>
        <p class="section-label">Blog</p>
        <h2 class="section-title">Latest Articles</h2>
      </div>
      <a href="/blog" class="btn-ghost border border-gray-200 dark:border-gray-700 shrink-0">
        All Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latest.map((post, i) => (
        <article
          class="group card flex flex-col"
          data-animate
          style={`animation-delay: ${i * 120}ms`}
        >
          <!-- Image -->
          {post.data.featuredImage && (
            <div class="overflow-hidden aspect-[16/9] bg-gray-100 dark:bg-gray-800">
              <img
                src={post.data.featuredImage}
                alt={post.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}

          <div class="p-6 flex flex-col flex-1">
            <!-- Categories -->
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.categories.slice(0, 2).map((cat) => (
                <span class="tag text-xs">{cat}</span>
              ))}
            </div>

            <!-- Title -->
            <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white
                       line-clamp-2 mb-2 group-hover:text-brand-600 dark:group-hover:text-brand-400
                       transition-colors duration-200">
              <a href={`/blog/${post.id}`} class="stretched-link">
                {post.data.title}
              </a>
            </h3>

            <!-- Excerpt -->
            <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-4 flex-1">
              {post.data.excerpt}
            </p>

            <!-- Meta -->
            <div class="flex items-center justify-between text-xs text-gray-400 mt-auto pt-4 border-t border-gray-100 dark:border-gray-800">
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {post.data.readingTime || estimateReadingTime(post.body || '')} min read
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
