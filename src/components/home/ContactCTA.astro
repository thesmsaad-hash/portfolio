---
// Contact CTA banner
---

<section class="section relative overflow-hidden bg-gray-950">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-900/50 via-gray-950 to-accent-900/30"></div>

  <!-- Orbs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full blur-3xl bg-brand-600/20 pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full blur-3xl bg-accent-500/20 pointer-events-none"></div>

  <!-- Grid -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="container-custom relative z-10 text-center text-white">
    <div data-animate>
      <p class="section-label !text-brand-400 mb-4">Let's Work Together</p>
      <h2 class="section-title !text-white text-4xl md:text-5xl lg:text-6xl mb-6">
        Ready to Create Something<br />
        <span class="gradient-text">Extraordinary?</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-xl mx-auto mb-10">
        Whether you need a YouTube series, motion graphics, or a complete AI content pipeline —
        let's build something your audience will never forget.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/contact" class="btn-primary px-10 py-4 text-base">
          Start a Project
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="mailto:thesmsaad@gmail.com" class="btn-secondary px-10 py-4 text-base">
          Send an Email
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap items-center justify-center gap-6 mt-12 text-gray-400 text-sm">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          Fast Turnaround
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          Unlimited Revisions
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          5-Star Reviews
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          NDA Available
        </span>
      </div>
    </div>
  </div>
</section>
