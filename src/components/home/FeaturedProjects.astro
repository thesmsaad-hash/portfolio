---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<section id="featured-projects" class="section bg-white dark:bg-surface-dark">
  <div class="container-custom">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <p class="section-label">Portfolio ⭐</p>
      <h2 class="section-title mb-4">Featured Work</h2>
      <p class="section-subtitle mx-auto">
        A selection of my best projects across video editing, motion graphics, and AI content creation.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((project, i) => (
        <article
          class="group card overflow-hidden"
          data-animate
          style={`animation-delay: ${i * 100}ms`}
        >
          <!-- Thumbnail -->
          <div class="relative overflow-hidden aspect-video bg-gray-100 dark:bg-gray-800">
            <img
              src={project.data.thumbnail}
              alt={project.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <!-- Overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-transparent to-transparent
                     opacity-0 group-hover:opacity-100 transition-opacity duration-300
                     flex items-end p-4"
            >
              <a
                href={`/portfolio/${project.id}`}
                class="btn-primary text-sm px-4 py-2 w-full justify-center"
              >
                View Project
              </a>
            </div>
            <!-- Category badge -->
            <div class="absolute top-3 left-3">
              <span class="tag text-xs">{project.data.category}</span>
            </div>
            <!-- Duration badge (if video) -->
            {project.data.videoDuration && (
              <div class="absolute top-3 right-3">
                <span class="px-2 py-1 rounded-md bg-black/70 text-white text-xs font-mono">
                  {project.data.videoDuration}
                </span>
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white mb-1 line-clamp-1">
              {project.data.title}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">
              {project.data.shortDescription}
            </p>

            <!-- Tools -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.data.tools.slice(0, 3).map((tool) => (
                <span class="px-2 py-0.5 rounded-md text-xs bg-gray-100 dark:bg-gray-800
                             text-gray-600 dark:text-gray-400">
                  {tool}
                </span>
              ))}
              {project.data.tools.length > 3 && (
                <span class="px-2 py-0.5 rounded-md text-xs bg-gray-100 dark:bg-gray-800
                             text-gray-500 dark:text-gray-500">
                  +{project.data.tools.length - 3} more
                </span>
              )}
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">
                {new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(project.data.completionDate)}
              </span>
              <a
                href={`/portfolio/${project.id}`}
                class="text-sm font-semibold text-brand-600 dark:text-brand-400
                       hover:text-brand-500 transition-colors
                       flex items-center gap-1 group/link"
                aria-label={`View ${project.data.title}`}
              >
                Details
                <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-animate>
      <a href="/portfolio" class="btn-outline px-8 py-3">
        View All Projects
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
