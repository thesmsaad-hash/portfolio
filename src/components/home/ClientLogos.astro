---
import { clients } from '../../data/timeline';
---

<section class="py-12 bg-gray-50 dark:bg-surface-dark-secondary overflow-hidden">
  <div class="container-custom">
    <p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-8" data-animate>
      Trusted by creators &amp; brands worldwide
    </p>

    <!-- Infinite scroll ticker -->
    <div class="relative" data-animate>
      <!-- Fade edges -->
      <div class="absolute left-0 top-0 bottom-0 w-16 z-10
                  bg-gradient-to-r from-gray-50 dark:from-surface-dark-secondary to-transparent"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 z-10
                  bg-gradient-to-l from-gray-50 dark:from-surface-dark-secondary to-transparent"></div>

      <div class="flex overflow-hidden gap-6">
        {/* Double the items for seamless loop */}
        {[...clients, ...clients].map((client, i) => (
          <div
            class="client-logo-item flex-shrink-0 flex items-center gap-3 px-6 py-4
                   rounded-2xl bg-white dark:bg-surface-dark-tertiary
                   border border-gray-100 dark:border-gray-800
                   shadow-sm"
          >
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center
                     text-white text-sm font-black"
              style={`background: ${client.color}`}
            >
              {client.initial}
            </div>
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 whitespace-nowrap">
              {client.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .flex.overflow-hidden > div {
    animation: ticker 30s linear infinite;
    display: flex;
    gap: 1.5rem;
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flex.overflow-hidden > div {
      animation: none;
    }
  }
</style>
