---
import { skills } from '../../data/skills';
import { software } from '../../data/skills';

const categories = [
  { id: 'video', label: 'Video Editing', color: 'from-blue-500 to-indigo-500' },
  { id: 'motion', label: 'Motion Graphics', color: 'from-purple-500 to-pink-500' },
  { id: 'design', label: 'Design', color: 'from-orange-500 to-red-500' },
  { id: 'ai', label: 'AI Tools', color: 'from-green-500 to-teal-500' },
  { id: 'audio', label: 'Audio', color: 'from-yellow-500 to-orange-500' },
];
---

<section class="section bg-gray-50 dark:bg-surface-dark-secondary">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Skills Progress Bars -->
      <div>
        <div class="mb-10" data-animate>
          <p class="section-label">Expertise</p>
          <h2 class="section-title text-3xl md:text-4xl mb-4">Skills &amp; Proficiency</h2>
          <p class="section-subtitle text-base">
            Years of hands-on experience across industry-leading tools and platforms.
          </p>
        </div>

        <div class="space-y-5">
          {skills.slice(0, 8).map((skill, i) => {
            const cat = categories.find((c) => c.id === skill.category);
            return (
              <div
                data-animate
                style={`animation-delay: ${i * 80}ms`}
              >
                <div class="flex justify-between items-center mb-2">
                  <span class="text-sm font-semibold text-gray-800 dark:text-gray-200">
                    {skill.name}
                  </span>
                  <span class="text-xs font-bold text-brand-600 dark:text-brand-400">
                    {skill.level}%
                  </span>
                </div>
                <div class="progress-bar">
                  <div
                    class={`h-full rounded-full bg-gradient-to-r ${cat?.color || 'from-brand-500 to-brand-400'}
                             transition-all duration-1000 ease-out`}
                    style="width: 0%"
                    data-progress={skill.level}
                  ></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Software Grid -->
      <div>
        <div class="mb-10" data-animate>
          <p class="section-label">Software</p>
          <h2 class="section-title text-3xl md:text-4xl mb-4">Tools I Use</h2>
          <p class="section-subtitle text-base">
            From industry standards to cutting-edge AI tools — always on the leading edge.
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {software.map((sw, i) => (
            <div
              class="glass-card hover:scale-105 text-center cursor-default"
              data-animate
              style={`animation-delay: ${i * 50}ms`}
              title={sw.name}
            >
              <div class="text-3xl mb-2">{sw.icon}</div>
              <p class="text-xs font-semibold text-gray-700 dark:text-gray-300 truncate">{sw.name}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animate progress bars on scroll
  const progressObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const bars = entry.target.querySelectorAll('[data-progress]');
        bars.forEach((bar) => {
          const level = (bar as HTMLElement).dataset.progress || '0';
          setTimeout(() => {
            (bar as HTMLElement).style.width = `${level}%`;
          }, 200);
        });
        progressObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  const section = document.querySelector('[data-progress]')?.closest('section');
  if (section) progressObserver.observe(section);
</script>
