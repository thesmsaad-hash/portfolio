---
// src/components/blog/SubscribeForm.astro
---
<div class="mt-16 bg-gray-50 dark:bg-surface-dark-secondary rounded-2xl p-8 md:p-12 border border-gray-100 dark:border-gray-800 text-center" data-animate>
  <div class="max-w-2xl mx-auto">
    <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-500/10 text-brand-500 mb-6">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <h3 class="font-display font-bold text-2xl md:text-3xl text-gray-900 dark:text-white mb-4">
      Get the Latest Insights
    </h3>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      Join my newsletter to get my best tips on video editing, AI content creation, and growing on YouTube delivered straight to your inbox.
    </p>
    
    <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <!-- Replace YOUR_ACCESS_KEY_HERE with your actual Web3Forms access key -->
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
      
      <input 
        type="email" 
        name="email" 
        placeholder="your@email.com" 
        required
        class="input flex-1 py-3 bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700"
      />
      <!-- Honeypot for Web3Forms -->
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
      <button type="submit" class="btn-primary py-3 px-8 whitespace-nowrap">
        Subscribe
      </button>
    </form>
    <p class="text-xs text-gray-400 mt-4">
      No spam. Unsubscribe at any time.
    </p>
  </div>
</div>
