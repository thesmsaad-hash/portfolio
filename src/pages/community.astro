---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Community" 
  description="Join SM SAAD's exclusive community of video editors, AI content creators, and motion graphics artists."
>
  <!-- Hero Section -->
  <section class="pt-32 pb-10 bg-white dark:bg-surface-dark relative overflow-hidden border-b border-gray-100 dark:border-gray-800">
    <div class="absolute inset-0 bg-brand-500/5 dark:bg-brand-500/10 pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 rounded-full blur-3xl bg-brand-600/10 pointer-events-none"></div>
    
    <div class="container-custom text-center relative z-10" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 font-medium text-sm mb-6 border border-brand-200 dark:border-brand-800/30">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        Community Forum
      </div>
      
      <h1 class="font-display font-black text-4xl md:text-5xl text-gray-900 dark:text-white mb-6">
        The Creator <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-brand-400">Board</span>
      </h1>
      
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Ask questions, share your work, and discuss video editing and AI. 
      </p>
    </div>
  </section>

  <!-- Community Board (Disqus Embed) -->
  <section class="py-16 bg-white dark:bg-surface-dark min-h-screen">
    <div class="container-custom max-w-4xl mx-auto" data-animate>
      <!-- Disqus Script -->
      <div id="disqus_thread" class="text-gray-900 dark:text-white"></div>
      <script is:inline>
        var disqus_config = function () {
          this.page.url = window.location.href;  
          this.page.identifier = 'community-board'; 
        };
        (function() { // DON'T EDIT BELOW THIS LINE
          var d = document, s = d.createElement('script');
          s.src = 'https://smsaad-online.disqus.com/embed.js';
          s.setAttribute('data-timestamp', +new Date());
          (d.head || d.body).appendChild(s);
        })();
      </script>
      <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">community board powered by Disqus.</a></noscript>
    </div>
  </section>
</BaseLayout>
