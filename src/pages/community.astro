---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Community" 
  description="Join SM SAAD's exclusive community of video editors, AI content creators, and motion graphics artists."
>
  <div class="pt-24 min-h-screen bg-gray-50 dark:bg-surface-dark flex flex-col">
    <div class="container-custom flex-grow py-8 max-w-7xl mx-auto flex flex-col lg:flex-row gap-6 h-full">
      
      <!-- Sidebar (Channels & Online Users) -->
      <aside class="w-full lg:w-64 flex flex-col gap-6 flex-shrink-0">
        
        <!-- Channels -->
        <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800/60">
          <h3 class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3 px-2">Channels</h3>
          <ul class="space-y-1">
            <li>
              <a href="#" class="flex items-center gap-3 px-2 py-2 rounded-lg bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 font-medium">
                <span class="text-lg">📢</span> General
              </a>
            </li>
            <!-- ... other channels omitted for brevity, but you get the idea ... -->
          </ul>
        </div>

        <!-- Online Users -->
        <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-gray-100 dark:border-gray-800/60 flex-grow">
          <div class="flex items-center justify-between mb-3 px-2">
            <h3 class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">Online</h3>
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          </div>
          <ul id="online-users-list" class="space-y-2">
            <!-- Populated via Supabase Presence -->
          </ul>
        </div>
      </aside>

      <!-- Main Feed -->
      <main class="flex-grow flex flex-col bg-white dark:bg-surface-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800/60 overflow-hidden min-h-[600px] h-[80vh]">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700/50 flex items-center justify-between bg-white/50 dark:bg-surface-800/50 backdrop-blur-sm sticky top-0 z-10">
          <h2 class="text-lg font-bold text-gray-900 dark:text-white flex items-center gap-2">
            ✨ Welcome to the Community
          </h2>
          <div class="flex items-center gap-3">
             <div class="relative">
                <input type="text" id="search-input" placeholder="Search messages..." class="bg-gray-100 dark:bg-surface-700 text-sm rounded-full px-4 py-1.5 focus:outline-none focus:ring-2 focus:ring-brand-500" />
             </div>
             <button id="auth-btn" class="text-sm font-medium px-4 py-1.5 bg-brand-600 text-white rounded-full hover:bg-brand-500 transition-colors">
               Login
             </button>
          </div>
        </div>

        <!-- Messages Area -->
        <div id="messages-container" class="flex-grow p-6 overflow-y-auto space-y-8 bg-gray-50/50 dark:bg-[#111118]/50">
          <div class="text-center text-gray-500 mt-10">Loading messages...</div>
        </div>

        <!-- TipTap Input Area -->
        <div id="composer-area" class="p-4 border-t border-gray-100 dark:border-gray-700/50 bg-white dark:bg-surface-800 hidden">
          <div class="flex flex-col gap-2 bg-gray-50 dark:bg-surface-900 border border-gray-200 dark:border-gray-700 rounded-xl p-3 focus-within:ring-2 focus-within:ring-brand-500/50 focus-within:border-brand-500 transition-all">
            
            <!-- TipTap Toolbar -->
            <div class="flex items-center gap-2 pb-2 border-b border-gray-200 dark:border-gray-700 mb-2">
              <button id="btn-bold" class="p-1.5 text-gray-500 hover:text-brand-500 rounded"><strong class="font-serif">B</strong></button>
              <button id="btn-italic" class="p-1.5 text-gray-500 hover:text-brand-500 rounded"><em class="font-serif">I</em></button>
              <div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1"></div>
              
              <!-- Image Upload -->
              <label class="p-1.5 text-gray-500 hover:text-brand-500 rounded cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                <input type="file" id="image-upload" class="hidden" accept="image/*" />
              </label>
              <span id="upload-status" class="text-xs text-brand-500 ml-2 hidden">Uploading...</span>
            </div>
            
            <!-- Editor Container -->
            <div id="tiptap-editor" class="min-h-[60px] text-gray-900 dark:text-white prose dark:prose-invert max-w-none text-sm outline-none"></div>
            
            <div class="flex justify-end mt-2">
              <button id="btn-send" class="p-2 bg-brand-600 hover:bg-brand-500 text-white rounded-lg transition-colors flex items-center justify-center gap-2 px-4 font-medium text-sm cursor-pointer">
                Send <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </div>
          </div>
        </div>
        
        <div id="login-prompt" class="p-4 border-t border-gray-100 dark:border-gray-700/50 bg-white dark:bg-surface-800 text-center">
           <p class="text-sm text-gray-500">Please <button id="auth-btn-bottom" class="text-brand-500 font-bold hover:underline">log in</button> to join the conversation.</p>
        </div>

      </main>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase';
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Image from '@tiptap/extension-image';

  let currentUser = null;
  let editor = null;

  const authBtn = document.getElementById('auth-btn');
  const authBtnBottom = document.getElementById('auth-btn-bottom');
  const composerArea = document.getElementById('composer-area');
  const loginPrompt = document.getElementById('login-prompt');
  const messagesContainer = document.getElementById('messages-container');
  const searchInput = document.getElementById('search-input');

  // TipTap Initialization
  function initEditor() {
    editor = new Editor({
      element: document.getElementById('tiptap-editor'),
      extensions: [StarterKit, Image],
      content: '',
      editorProps: {
        attributes: {
          class: 'focus:outline-none min-h-[60px]',
        },
      },
    });

    document.getElementById('btn-bold').addEventListener('click', () => editor.chain().focus().toggleBold().run());
    document.getElementById('btn-italic').addEventListener('click', () => editor.chain().focus().toggleItalic().run());
  }

  // Handle Image Upload directly to Supabase Storage
  document.getElementById('image-upload').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file || !currentUser) return;

    const statusEl = document.getElementById('upload-status');
    statusEl.classList.remove('hidden');
    statusEl.textContent = 'Uploading...';

    try {
      const fileExt = file.name.split('.').pop();
      const fileName = `${Date.now()}-${Math.random().toString(36).substring(2)}.${fileExt}`;
      const filePath = `${currentUser.id}/${fileName}`;

      const { error } = await supabase.storage.from('community-images').upload(filePath, file);
      if (error) throw error;

      const { data: { publicUrl } } = supabase.storage.from('community-images').getPublicUrl(filePath);
      
      if (publicUrl) {
        editor.chain().focus().setImage({ src: publicUrl }).run();
      }
    } catch (err) {
      console.error('Upload failed', err);
      statusEl.textContent = 'Failed';
      setTimeout(() => statusEl.classList.add('hidden'), 3000);
      return;
    } 
    
    statusEl.classList.add('hidden');
    e.target.value = ''; // reset
  });

  // Supabase Auth logic
  async function handleAuth() {
    if (currentUser) {
      await supabase.auth.signOut();
    } else {
      await supabase.auth.signInWithOAuth({ 
        provider: 'google',
        options: {
          redirectTo: `${window.location.origin}/community`
        }
      });
    }
  }

  authBtn.addEventListener('click', handleAuth);
  if (authBtnBottom) authBtnBottom.addEventListener('click', handleAuth);

  supabase.auth.onAuthStateChange((event, session) => {
    if (session?.user) {
      currentUser = session.user;
      authBtn.textContent = 'Logout';
      composerArea.classList.remove('hidden');
      loginPrompt.classList.add('hidden');
      if (!editor) initEditor();
    } else {
      currentUser = null;
      authBtn.textContent = 'Login with Google';
      composerArea.classList.add('hidden');
      loginPrompt.classList.remove('hidden');
    }
  });

  // Fetch and Render Messages
  async function fetchMessages(searchQuery = '') {
    let query = supabase.from('messages').select('*, profiles(full_name, avatar_url)').order('created_at', { ascending: true });
    
    // Simple ilike search (simulate full text search for now)
    if (searchQuery) {
      query = query.ilike('content', `%${searchQuery}%`);
    }

    const { data, error } = await query;
    if (error) {
      console.error(error);
      return;
    }

    renderMessages(data);
  }

  function renderMessages(messages) {
    if (!messages || messages.length === 0) {
      messagesContainer.innerHTML = '<div class="text-center text-gray-500 mt-10">No messages yet. Start the conversation!</div>';
      return;
    }

    messagesContainer.innerHTML = messages.map(msg => `
      <div class="group flex gap-4">
        <div class="flex-shrink-0">
          <img src="${msg.profiles?.avatar_url || 'https://ui-avatars.com/api/?name=User'}" class="w-10 h-10 rounded-full object-cover" />
        </div>
        <div class="flex-grow overflow-hidden">
          <div class="flex items-baseline gap-2 mb-1">
            <span class="font-bold text-gray-900 dark:text-white">${msg.profiles?.full_name || 'Anonymous'}</span>
            <span class="text-xs text-gray-500">${new Date(msg.created_at).toLocaleTimeString()}</span>
          </div>
          <div class="text-gray-800 dark:text-gray-200 mb-3 prose prose-sm dark:prose-invert">
            ${msg.content}
          </div>
        </div>
      </div>
    `).join('');
    
    // Auto scroll to bottom
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  // Handle message send
  document.getElementById('btn-send').addEventListener('click', async () => {
    if (!editor || !currentUser) return;
    
    const content = editor.getHTML();
    if (content === '<p></p>') return;

    // Optimistic UI could go here
    editor.commands.clearContent();

    await supabase.from('messages').insert([
      { user_id: currentUser.id, content: content }
    ]);
  });

  // Supabase Realtime Subscription
  supabase
    .channel('public:messages')
    .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' }, payload => {
      // Refresh messages (or ideally just append the new one)
      fetchMessages();
    })
    .subscribe();

  // Search logic
  let debounceTimeout;
  searchInput.addEventListener('input', (e) => {
    clearTimeout(debounceTimeout);
    debounceTimeout = setTimeout(() => {
      fetchMessages(e.target.value);
    }, 300);
  });

  // Initial load
  fetchMessages();
</script>

<style is:global>
  /* TipTap specific styles for the editor */
  .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    color: #adb5bd;
    pointer-events: none;
    height: 0;
  }
  .ProseMirror img {
    max-width: 100%;
    border-radius: 0.5rem;
  }
</style>
