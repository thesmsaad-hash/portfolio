---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Community | SM SAAD"
  description="Join SM SAAD's exclusive community of video editors, AI content creators, and motion graphics artists. Ask questions, share your work, and connect."
>
  <div class="pt-24 min-h-screen bg-[#0d0d14]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 flex flex-col lg:flex-row gap-6">

      <!-- Sidebar -->
      <aside class="w-full lg:w-64 flex-shrink-0 flex flex-col gap-5">

        <!-- Channels -->
        <div class="bg-[#13131f] rounded-2xl p-5 border border-white/5">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-4 px-1">Channels</h3>
          <ul class="space-y-1">
            <li>
              <a href="#general" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-brand-600/10 text-brand-400 font-semibold text-sm">
                <span class="text-base">📢</span> General
              </a>
            </li>
            <li>
              <a href="#editing" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition-colors">
                <span class="text-base">🎬</span> Editing
              </a>
            </li>
            <li>
              <a href="#ai-tools" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition-colors">
                <span class="text-base">🤖</span> AI Tools
              </a>
            </li>
            <li>
              <a href="#ideas" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition-colors">
                <span class="text-base">💡</span> Ideas
              </a>
            </li>
            <li>
              <a href="#showcase" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition-colors">
                <span class="text-base">🚀</span> Showcase
              </a>
            </li>
          </ul>
        </div>

        <!-- Community Stats -->
        <div class="bg-[#13131f] rounded-2xl p-5 border border-white/5">
          <h3 class="text-[10px] font-bold uppercase tracking-widest text-gray-500 mb-4 px-1">Community</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between px-1">
              <span class="text-xs text-gray-400">Members</span>
              <span class="text-xs font-bold text-white">Growing</span>
            </div>
            <div class="flex items-center justify-between px-1">
              <span class="text-xs text-gray-400">Discussions</span>
              <span class="text-xs font-bold text-brand-400">GitHub</span>
            </div>
            <div class="flex items-center justify-between px-1">
              <span class="text-xs text-gray-400">Auth</span>
              <span class="text-xs font-bold text-green-400 flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </span>
            </div>
          </div>
        </div>

        <!-- About Card -->
        <div class="bg-gradient-to-br from-brand-600/20 to-purple-600/10 rounded-2xl p-5 border border-brand-500/20">
          <div class="flex items-center gap-3 mb-3">
            <img
              src="https://avatars.githubusercontent.com/thesmsaad-hash"
              onerror="this.src='https://ui-avatars.com/api/?name=SM+SAAD&background=dc2626&color=fff'"
              class="w-9 h-9 rounded-full border-2 border-brand-500/40"
              alt="SM SAAD"
            />
            <div>
              <p class="text-white font-bold text-sm">SM SAAD</p>
              <p class="text-brand-400 text-xs">Community Host</p>
            </div>
          </div>
          <p class="text-gray-400 text-xs leading-relaxed">
            Video editor, AI creator & motion artist. Ask me anything about editing workflows, tools, and content creation!
          </p>
        </div>
      </aside>

      <!-- Main Feed -->
      <main class="flex-grow flex flex-col min-h-[600px]">

        <!-- Header -->
        <div class="bg-[#13131f] rounded-t-2xl px-6 py-4 border border-white/5 border-b-0 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div>
            <h1 class="text-xl font-bold text-white flex items-center gap-2">
              ✨ Welcome to the Community
            </h1>
            <p class="text-xs text-gray-500 mt-0.5">Sign in with GitHub to join the conversation</p>
          </div>
          <div class="flex items-center gap-2 text-xs text-gray-500">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Powered by GitHub Discussions
          </div>
        </div>

        <!-- Giscus Embed -->
        <div class="bg-[#13131f] rounded-b-2xl border border-white/5 p-6 flex-grow" id="giscus-container">
          <!-- GISCUS WIDGET LOADS HERE -->
          <script
            src="https://giscus.app/client.js"
            data-repo="thesmsaad-hash/portfolio"
            data-repo-id="REPLACE_WITH_REPO_ID"
            data-category="General"
            data-category-id="REPLACE_WITH_CATEGORY_ID"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="top"
            data-theme="dark_dimmed"
            data-lang="en"
            data-loading="lazy"
            crossorigin="anonymous"
            async
          ></script>
        </div>

      </main>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Override Giscus iframe styling to blend with the page */
  .giscus,
  .giscus-frame {
    width: 100%;
    border: none;
    color-scheme: dark;
  }
</style>
