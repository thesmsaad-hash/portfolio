---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Community" 
  description="Join SM SAAD's exclusive community of video editors, AI content creators, and motion graphics artists."
>
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-white dark:bg-surface-dark relative overflow-hidden">
    <div class="absolute inset-0 bg-brand-500/5 dark:bg-brand-500/10 pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 rounded-full blur-3xl bg-brand-600/10 pointer-events-none"></div>
    
    <div class="container-custom text-center relative z-10" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 font-medium text-sm mb-6 border border-brand-200 dark:border-brand-800/30">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        Join the Movement
      </div>
      
      <h1 class="font-display font-black text-5xl md:text-7xl text-gray-900 dark:text-white mb-6 leading-tight">
        Master Your Craft. <br class="hidden md:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-brand-400">Build Your Empire.</span>
      </h1>
      
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Connect with a private community of elite video editors and AI content creators. Share strategies, get feedback on your work, and scale your content business.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <!-- REPLACE THIS LINK with your actual Discord/Telegram/Skool link -->
        <a href="https://discord.com" target="_blank" rel="noopener noreferrer" class="btn-primary py-4 px-8 text-lg w-full sm:w-auto">
          Join the Discord Server
        </a>
        <a href="#features" class="btn-ghost border border-gray-200 dark:border-gray-800 py-4 px-8 text-lg w-full sm:w-auto">
          See What's Inside
        </a>
      </div>
      
      <p class="text-sm text-gray-500 dark:text-gray-500 mt-6">
        It's 100% free to join.
      </p>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 bg-gray-50 dark:bg-surface-dark-secondary">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16" data-animate>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-gray-900 dark:text-white mb-4">
          Why you should join us
        </h2>
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          We are more than just a chat room. We are a collective of creators pushing the boundaries of what's possible with video and AI.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="card p-8 bg-white dark:bg-surface-dark hover:-translate-y-2 transition-transform duration-300" data-animate style="animation-delay: 100ms">
          <div class="w-14 h-14 rounded-2xl bg-brand-50 dark:bg-brand-900/20 text-brand-600 flex items-center justify-center mb-6">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white mb-3">Project Feedback</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Share your latest edits, thumbnails, or AI generations and get constructive feedback from professionals to help you improve faster.
          </p>
        </div>
        
        <!-- Feature 2 -->
        <div class="card p-8 bg-white dark:bg-surface-dark hover:-translate-y-2 transition-transform duration-300" data-animate style="animation-delay: 200ms">
          <div class="w-14 h-14 rounded-2xl bg-brand-50 dark:bg-brand-900/20 text-brand-600 flex items-center justify-center mb-6">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white mb-3">AI & Automation Workflows</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Stay ahead of the curve. Learn the exact prompts, tools, and automation pipelines I use to speed up my content creation by 10x.
          </p>
        </div>
        
        <!-- Feature 3 -->
        <div class="card p-8 bg-white dark:bg-surface-dark hover:-translate-y-2 transition-transform duration-300" data-animate style="animation-delay: 300ms">
          <div class="w-14 h-14 rounded-2xl bg-brand-50 dark:bg-brand-900/20 text-brand-600 flex items-center justify-center mb-6">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white mb-3">Client Acquisition</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Learn how to package your services, negotiate rates, and land high-paying clients in the creator economy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-white dark:bg-surface-dark">
    <div class="container-custom">
      <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-[2rem] p-10 md:p-16 text-center text-white relative overflow-hidden" data-animate>
        <div class="absolute inset-0 bg-gray-900/10 mix-blend-overlay"></div>
        <div class="relative z-10">
          <h2 class="font-display font-black text-3xl md:text-5xl mb-6">Ready to level up?</h2>
          <p class="text-brand-100 text-lg max-w-2xl mx-auto mb-10">
            Stop trying to figure it all out on your own. Join a community of driven creators who are building the future of content.
          </p>
          <!-- REPLACE THIS LINK with your actual Discord/Telegram/Skool link -->
          <a href="https://discord.com" target="_blank" rel="noopener noreferrer" class="btn bg-white text-brand-700 hover:bg-gray-50 py-4 px-10 text-lg rounded-full font-bold transition-transform hover:scale-105">
            Get Instant Access
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
