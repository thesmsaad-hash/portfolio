---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, estimateReadingTime, generateArticleSchema, SITE_URL } from '../../utils/seo';
import SubscribeForm from '../../components/blog/SubscribeForm.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const readingTime = post.data.readingTime || estimateReadingTime(post.body || '');

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      p.data.categories.some((c) => post.data.categories.includes(c))
  )
  .slice(0, 3);

const schema = generateArticleSchema({
  title: post.data.title,
  excerpt: post.data.excerpt,
  date: post.data.date,
  slug: post.id,
  image: post.data.featuredImage,
});
---

<BaseLayout
  title={post.data.seoTitle || post.data.title}
  description={post.data.seoDescription || post.data.excerpt}
  image={post.data.featuredImage}
  type="article"
  schema={schema}
>
  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-brand-500 to-accent-500 z-50 w-0 transition-none"
       aria-hidden="true"></div>

  <!-- Article -->
  <article class="pt-24" itemscope itemtype="https://schema.org/Article">
    <!-- Hero Image -->
    {post.data.featuredImage && (
      <div class="relative h-[40vh] md:h-[55vh] overflow-hidden">
        <img
          src={post.data.featuredImage}
          alt={post.data.title}
          class="w-full h-full object-cover"
          loading="eager"
          itemprop="image"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-white dark:from-surface-dark via-transparent to-transparent"></div>
      </div>
    )}

    <div class="container-custom max-w-4xl">
      <!-- Header -->
      <header class="py-10 border-b border-gray-100 dark:border-gray-800">
        <!-- Categories -->
        <div class="flex flex-wrap gap-2 mb-6">
          {post.data.categories.map((cat) => (
            <a href={`/blog?category=${cat}`} class="tag hover:bg-brand-100 dark:hover:bg-brand-900/50 transition-colors">
              {cat}
            </a>
          ))}
        </div>

        <!-- Title -->
        <h1
          class="font-display font-black text-4xl md:text-5xl lg:text-6xl
                 text-gray-900 dark:text-white leading-tight mb-6"
          itemprop="headline"
        >
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-6 text-sm text-gray-500 dark:text-gray-400">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-brand-gradient flex items-center justify-center text-white text-xs font-bold">
              S
            </div>
            <span itemprop="author">{post.data.author}</span>
          </div>
          <time datetime={post.data.date.toISOString()} itemprop="datePublished">
            {formatDate(post.data.date)}
          </time>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {readingTime} min read
          </span>

          <!-- Actions -->
          <div class="ml-auto flex items-center gap-2">
            <!-- Like -->
            <button
              id="like-btn"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm
                     text-gray-500 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-950/30
                     transition-all duration-200"
              aria-label="Like this post"
              data-slug={post.id}
            >
              <svg id="like-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <span id="like-count">0</span>
            </button>

            <!-- Bookmark -->
            <button
              id="bookmark-btn"
              class="p-1.5 rounded-lg text-gray-500 hover:text-brand-500 hover:bg-brand-50 dark:hover:bg-brand-950/30 transition-all"
              aria-label="Bookmark"
              data-slug={post.id}
            >
              <svg id="bookmark-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
            </button>

            <!-- Copy link -->
            <button
              id="copy-link-btn"
              class="p-1.5 rounded-lg text-gray-500 hover:text-green-500 hover:bg-green-50 dark:hover:bg-green-950/30 transition-all"
              aria-label="Copy link"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
              </svg>
            </button>

            <!-- Print -->
            <button
              onclick="window.print()"
              class="p-1.5 rounded-lg text-gray-500 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/10 transition-all"
              aria-label="Print article"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
              </svg>
            </button>
          </div>
        </div>
      </header>

      <!-- Content + Sidebar -->
      <div class="py-10 grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Table of Contents (sidebar on lg) -->
        {headings.length > 2 && (
          <aside class="lg:col-span-1 hidden lg:block">
            <div class="sticky top-24 glass-card">
              <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-4 font-bold">
                Contents
              </h2>
              <nav>
                <ul class="space-y-2">
                  {headings.filter(h => h.depth <= 3).map((h) => (
                    <li style={`padding-left: ${(h.depth - 1) * 12}px`}>
                      <a
                        href={`#${h.slug}`}
                        class="text-xs text-gray-500 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400
                               transition-colors block py-1 leading-relaxed"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )}

        <!-- Article body -->
        <div class={`${headings.length > 2 ? 'lg:col-span-3' : 'lg:col-span-4'}`}>
          <div class="prose prose-lg dark:prose-dark max-w-none" itemprop="articleBody">
            <Content />
          </div>

          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-gray-100 dark:border-gray-800">
              <p class="text-xs uppercase tracking-wider text-gray-400 mb-3">Tags</p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-3 py-1 rounded-full text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Author card -->
          <div class="mt-10 glass-card">
            <div class="flex items-start gap-4">
              <img
                src="/images/profile.png"
                alt="SM SAAD"
                class="w-16 h-16 rounded-2xl object-cover shrink-0"
              />
              <div>
                <p class="font-display font-bold text-lg text-gray-900 dark:text-white">SM SAAD</p>
                <p class="text-sm text-gray-400 mb-3">Video Editor · Motion Graphics · AI Content Creator</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                  Professional video editor with 6+ years of experience creating cinematic content for YouTubers, brands, and creators worldwide. Specializing in AI-enhanced content pipelines and motion graphics.
                </p>
              </div>
            </div>
          </div>

          <!-- Share -->
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Share & Follow:</span>
            <a
              href={`https://twitter.com/intent/tweet?url=${SITE_URL}/blog/${post.id}&text=${encodeURIComponent(post.data.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost text-sm px-4 py-2 border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800"
            >
              X (Twitter)
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${SITE_URL}/blog/${post.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost text-sm px-4 py-2 border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800"
            >
              LinkedIn
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${SITE_URL}/blog/${post.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-ghost text-sm px-4 py-2 border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800"
            >
              Facebook
            </a>
            <a href="https://youtube.com/@smsaad" target="_blank" rel="noopener noreferrer" class="btn-ghost text-sm px-4 py-2 border border-gray-200 dark:border-gray-700 hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-600">
              YouTube
            </a>
            <a href="https://instagram.com/smsaad" target="_blank" rel="noopener noreferrer" class="btn-ghost text-sm px-4 py-2 border border-gray-200 dark:border-gray-700 hover:bg-pink-50 dark:hover:bg-pink-900/20 hover:text-pink-600">
              Instagram
            </a>
          </div>

          <!-- Subscribe Form -->
          <SubscribeForm />

          <!-- Comments & Likes (Disqus) -->
          <div class="mt-16 border-t border-gray-100 dark:border-gray-800 pt-12">
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-8">
              Comments & Discussion
            </h2>
            <div id="disqus_thread" class="text-gray-900 dark:text-white"></div>
            <script is:inline>
              var disqus_config = function () {
                this.page.url = window.location.href;  
                this.page.identifier = window.location.pathname; 
              };
              (function() { // DON'T EDIT BELOW THIS LINE
                var d = document, s = d.createElement('script');
                s.src = 'https://smsaad-online.disqus.com/embed.js';
                s.setAttribute('data-timestamp', +new Date());
                (d.head || d.body).appendChild(s);
              })();
            </script>
            <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
          </div>
        </div>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <div class="py-12 border-t border-gray-100 dark:border-gray-800">
          <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-8">
            Related Articles
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {related.map((p) => (
              <a href={`/blog/${p.id}`} class="group card overflow-hidden">
                {p.data.featuredImage && (
                  <div class="overflow-hidden aspect-video bg-gray-100 dark:bg-gray-800">
                    <img
                      src={p.data.featuredImage}
                      alt={p.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-4">
                  <h3 class="font-display font-bold text-base text-gray-900 dark:text-white line-clamp-2
                             group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    {p.data.title}
                  </h3>
                  <p class="text-xs text-gray-400 mt-1">{formatDate(p.data.date)}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<script>
  // Reading progress
  const progressBar = document.getElementById('reading-progress');
  const article = document.querySelector('article');

  window.addEventListener('scroll', () => {
    if (!progressBar || !article) return;
    const articleTop = article.getBoundingClientRect().top + window.scrollY;
    const articleHeight = article.offsetHeight;
    const scrolled = window.scrollY - articleTop;
    const percent = Math.min(Math.max((scrolled / articleHeight) * 100, 0), 100);
    progressBar.style.width = `${percent}%`;
  }, { passive: true });

  // Like button
  const likeBtn = document.getElementById('like-btn');
  const likeIcon = document.getElementById('like-icon');
  const likeCount = document.getElementById('like-count');
  const slug = likeBtn?.dataset.slug || '';

  const liked = JSON.parse(localStorage.getItem('liked-posts') || '[]') as string[];
  const likes = JSON.parse(localStorage.getItem('post-likes') || '{}') as Record<string, number>;

  const updateLike = () => {
    const count = likes[slug] || 0;
    if (likeCount) likeCount.textContent = String(count);
    if (likeIcon) {
      if (liked.includes(slug)) {
        likeIcon.setAttribute('fill', 'currentColor');
        likeBtn?.classList.add('text-red-500');
      } else {
        likeIcon.setAttribute('fill', 'none');
        likeBtn?.classList.remove('text-red-500');
      }
    }
  };

  updateLike();

  likeBtn?.addEventListener('click', () => {
    const idx = liked.indexOf(slug);
    if (idx === -1) {
      liked.push(slug);
      likes[slug] = (likes[slug] || 0) + 1;
    } else {
      liked.splice(idx, 1);
      likes[slug] = Math.max((likes[slug] || 1) - 1, 0);
    }
    localStorage.setItem('liked-posts', JSON.stringify(liked));
    localStorage.setItem('post-likes', JSON.stringify(likes));
    updateLike();
  });

  // Bookmark
  const bookmarkBtn = document.getElementById('bookmark-btn');
  const bookmarkIcon = document.getElementById('bookmark-icon');
  const bookmarks = JSON.parse(localStorage.getItem('bookmarks') || '[]') as string[];

  const updateBookmark = () => {
    if (bookmarkIcon) {
      bookmarkIcon.setAttribute('fill', bookmarks.includes(slug) ? 'currentColor' : 'none');
      bookmarkBtn?.classList.toggle('text-brand-500', bookmarks.includes(slug));
    }
  };

  updateBookmark();

  bookmarkBtn?.addEventListener('click', () => {
    const idx = bookmarks.indexOf(slug);
    if (idx === -1) bookmarks.push(slug);
    else bookmarks.splice(idx, 1);
    localStorage.setItem('bookmarks', JSON.stringify(bookmarks));
    updateBookmark();
  });

  // Copy link
  document.getElementById('copy-link-btn')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const btn = document.getElementById('copy-link-btn');
      btn?.classList.add('text-green-500');
      setTimeout(() => btn?.classList.remove('text-green-500'), 2000);
    } catch {}
  });

  // Recently viewed
  const viewed = JSON.parse(localStorage.getItem('recently-viewed') || '[]') as string[];
  if (!viewed.includes(slug)) {
    viewed.unshift(slug);
    localStorage.setItem('recently-viewed', JSON.stringify(viewed.slice(0, 10)));
  }
</script>
