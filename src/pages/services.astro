---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services, faqs } from '../data/services';
---

<BaseLayout
  title="Services"
  description="Professional video editing, motion graphics, VFX, AI content creation, and more. Starting from $25. Fast turnaround, unlimited revisions."
>
  <!-- Header -->
  <div class="pt-32 pb-16 bg-gradient-to-b from-gray-950 to-white dark:to-surface-dark relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-1/3 w-96 h-96 rounded-full blur-3xl bg-accent-500/10"></div>
    </div>
    <div class="container-custom text-center">
      <p class="section-label mb-3">What I Do</p>
      <h1 class="font-display font-black text-5xl md:text-7xl text-white mb-4 leading-none">Services</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Premium video production services with fast turnaround and unlimited revisions.
      </p>
    </div>
  </div>

  <!-- Services Grid -->
  <section class="section bg-white dark:bg-surface-dark">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {services.map((service, i) => (
          <article
            id={service.id}
            class="group relative glass-card border border-gray-100 dark:border-white/5
                   hover:border-brand-500/30 dark:hover:border-brand-400/20
                   transition-all duration-400 scroll-mt-24"
            data-animate
            style={`animation-delay: ${i * 60}ms`}
          >
            <!-- Glow on hover -->
            <div class="absolute inset-0 rounded-2xl bg-brand-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <!-- Icon -->
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300 inline-block">
              {service.icon}
            </div>

            <!-- Featured badge -->
            {service.featured && (
              <div class="absolute top-4 right-4">
                <span class="tag-accent text-xs">Popular</span>
              </div>
            )}

            <h2 class="font-display font-bold text-xl text-gray-900 dark:text-white mb-3">
              {service.title}
            </h2>

            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
              {service.description}
            </p>

            <!-- Features -->
            <ul class="space-y-2 mb-6">
              {service.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- Pricing -->
            {service.startingPrice && (
              <div class="flex items-center justify-between mb-4 text-sm">
                <span class="text-2xl font-display font-black text-brand-600 dark:text-brand-400">
                  {service.startingPrice}
                </span>
                {service.turnaround && (
                  <span class="text-gray-400 text-xs">{service.turnaround} turnaround</span>
                )}
              </div>
            )}

            <!-- CTA -->
            <a href="/contact" class="btn-primary w-full justify-center text-sm mt-auto">
              Get a Quote
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-gray-50 dark:bg-surface-dark-secondary">
    <div class="container-custom max-w-3xl">
      <div class="text-center mb-12" data-animate>
        <p class="section-label">FAQ</p>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details
            class="group glass-card cursor-pointer"
            data-animate
            style={`animation-delay: ${i * 80}ms`}
          >
            <summary class="flex items-center justify-between font-semibold text-gray-900 dark:text-white list-none py-2">
              {faq.question}
              <svg class="w-5 h-5 text-brand-500 transition-transform duration-300 group-open:rotate-45 shrink-0 ml-4"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
            </summary>
            <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12" data-animate>
        <p class="text-gray-500 dark:text-gray-400 mb-4">Still have questions?</p>
        <a href="/contact" class="btn-primary px-10 py-4">
          Contact Me Directly
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
