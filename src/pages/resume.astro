---
import BaseLayout from '../layouts/BaseLayout.astro';
import { timeline, stats } from '../data/timeline';
import { skills, software } from '../data/skills';
---

<BaseLayout
  title="Resume"
  description="SM SAAD's professional resume — Video Editor, Motion Graphics Artist, AI Content Creator with 6+ years of experience."
>
  <!-- Resume Header -->
  <div class="pt-32 pb-8 bg-gradient-to-b from-gray-950 to-white dark:to-surface-dark relative overflow-hidden">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-8">
        <div data-animate>
          <p class="section-label mb-2">My Resume</p>
          <h1 class="font-display font-black text-5xl md:text-6xl text-white leading-none">
            SM <span class="gradient-text">SAAD</span>
          </h1>
          <p class="text-gray-300 mt-2 text-lg">Podcast Video Editor · Reels Creator · Motion Graphics</p>
        </div>
        <a
          href="/resume.pdf"
          download
          class="btn-primary px-8 py-4 text-base shrink-0"
          data-animate
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Download PDF
        </a>
      </div>
    </div>
  </div>

  <div class="section bg-white dark:bg-surface-dark">
    <div class="container-custom max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Sidebar -->
        <aside class="space-y-8">
          <!-- Contact -->
          <div class="glass-card" data-animate>
            <h2 class="font-display font-bold text-lg text-gray-900 dark:text-white mb-4">Contact</h2>
            <ul class="space-y-3 text-sm">
              <li class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <a href="mailto:thesmsaad@gmail.com" class="hover:text-brand-500 transition-colors">
                  thesmsaad@gmail.com
                </a>
              </li>
              <li class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
                <a href="https://smsaad.online" class="hover:text-brand-500 transition-colors">smsaad.online</a>
              </li>
            </ul>
          </div>

          <!-- Skills -->
          <div class="glass-card" data-animate>
            <h2 class="font-display font-bold text-lg text-gray-900 dark:text-white mb-4">Skills</h2>
            <div class="space-y-3">
              {skills.slice(0, 10).map((skill) => (
                <div>
                  <div class="flex justify-between mb-1 text-xs">
                    <span class="text-gray-700 dark:text-gray-300 font-medium">{skill.name}</span>
                    <span class="text-brand-500">{skill.level}%</span>
                  </div>
                  <div class="progress-bar h-1.5">
                    <div class="h-full rounded-full bg-brand-gradient" data-progress={skill.level} style="width:0%"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Software -->
          <div class="glass-card" data-animate>
            <h2 class="font-display font-bold text-lg text-gray-900 dark:text-white mb-4">Software</h2>
            <div class="flex flex-wrap gap-2">
              {software.map((sw) => (
                <span class="flex items-center gap-1 px-2 py-1 rounded-lg text-xs bg-gray-100 dark:bg-gray-800
                             text-gray-600 dark:text-gray-400">
                  {sw.icon} {sw.name}
                </span>
              ))}
            </div>
          </div>

          <div class="glass-card" data-animate>
            <h2 class="font-display font-bold text-lg text-gray-900 dark:text-white mb-4">Certifications</h2>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">AI Applications & Prompt Engineering</p>
                  <p class="text-xs text-gray-400">edX · Sep 2024</p>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">Technology Entrepreneurship: Lab to Market</p>
                  <p class="text-xs text-gray-400">edX · May 2024</p>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">Project Management Fundamentals</p>
                  <p class="text-xs text-gray-400">IBM</p>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">UI and UX Developer</p>
                  <p class="text-xs text-gray-400">Larsen & Toubro</p>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">MongoDB Essentials</p>
                  <p class="text-xs text-gray-400">Larsen & Toubro</p>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-amber-500 mt-0.5">🏆</span>
                <div>
                  <p class="font-medium text-gray-800 dark:text-gray-200">U.S. Political Institutions</p>
                  <p class="text-xs text-gray-400">Harvard University</p>
                </div>
              </li>
            </ul>
          </div>
        </aside>

        <!-- Main content -->
        <main class="lg:col-span-2 space-y-10">
          <!-- About -->
          <section data-animate>
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-4 pb-2 border-b border-gray-100 dark:border-gray-800">
              About Me
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              Professional Video Editor specializing in Podcast Video Editing and Short-Form Reels with 1+ year of experience. I help Indian creators, coaches, and brands build powerful online presence through professional video content. B.Tech in Computer Science from SVCE Chittoor, currently pursuing a Master's in AI from Arena Animation.
            </p>
          </section>

          <!-- Stats -->
          <section data-animate>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              {stats.map((stat) => (
                <div class="glass-card text-center">
                  <div class="text-2xl mb-1">{stat.icon}</div>
                  <div class="font-display font-black text-2xl gradient-text">{stat.value}{stat.suffix}</div>
                  <div class="text-xs text-gray-400 mt-0.5">{stat.label}</div>
                </div>
              ))}
            </div>
          </section>

          <!-- Experience -->
          <section data-animate>
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-100 dark:border-gray-800">
              Experience
            </h2>
            <div class="space-y-6">
              {timeline.filter(t => t.type === 'work').map((item, i) => (
                <div class="relative pl-6 border-l-2 border-brand-500/30 hover:border-brand-500 transition-colors" data-animate style={`animation-delay:${i*80}ms`}>
                  <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-brand-gradient"></div>
                  <p class="text-xs font-bold text-brand-500 mb-1">{item.year}</p>
                  <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white">{item.title}</h3>
                  <p class="text-sm text-gray-500 mb-2">{item.org}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.description}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Education -->
          <section data-animate>
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-6 pb-2 border-b border-gray-100 dark:border-gray-800">
              Education
            </h2>
            <div class="space-y-4">
              {timeline.filter(t => t.type === 'education').map((item) => (
                <div class="glass-card">
                  <p class="text-xs font-bold text-green-500 mb-1">{item.year}</p>
                  <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white">{item.title}</h3>
                  <p class="text-sm text-gray-500 mb-2">{item.org}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{item.description}</p>
                </div>
              ))}
            </div>
          </section>
        </main>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const progressObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('[data-progress]').forEach((bar) => {
          const level = (bar as HTMLElement).dataset.progress || '0';
          setTimeout(() => { (bar as HTMLElement).style.width = `${level}%`; }, 200);
        });
        progressObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  const section = document.querySelector('[data-progress]')?.closest('section') || document.querySelector('[data-progress]')?.closest('div');
  if (section) progressObserver.observe(section);
</script>
