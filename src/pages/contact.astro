---
import BaseLayout from '../layouts/BaseLayout.astro';
import { socialLinks } from '../data/navigation';
---

<BaseLayout
  title="Contact"
  description="Get in touch with SM SAAD for video editing, motion graphics, AI content creation, and more. Fast response guaranteed."
>
  <!-- Header -->
  <div class="pt-32 pb-16 bg-gradient-to-b from-gray-950 to-white dark:to-surface-dark relative overflow-hidden">
    <div class="absolute top-0 left-1/3 w-96 h-96 rounded-full blur-3xl bg-brand-600/10 pointer-events-none"></div>
    <div class="container-custom text-center">
      <p class="section-label mb-3">Get In Touch</p>
      <h1 class="font-display font-black text-5xl md:text-7xl text-white mb-4 leading-none">Contact</h1>
      <p class="text-gray-400 text-lg max-w-lg mx-auto">
        Have a project in mind? Let's create something extraordinary together.
      </p>
    </div>
  </div>

  <section class="section bg-white dark:bg-surface-dark">
    <div class="container-custom max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          <div data-animate>
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-6">
              Let's Connect
            </h2>

            <div class="space-y-4">
              <a
                href="mailto:thesmsaad@gmail.com"
                class="flex items-center gap-4 p-4 glass-card hover:border-brand-500/30 transition-all group"
              >
                <div class="w-12 h-12 rounded-xl bg-brand-gradient flex items-center justify-center text-white shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 mb-0.5">Email</p>
                  <p class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                    thesmsaad@gmail.com
                  </p>
                </div>
              </a>

              <div class="p-4 glass-card">
                <div class="flex items-center gap-3 mb-4">
                  <span class="w-2.5 h-2.5 rounded-full bg-green-400 animate-pulse"></span>
                  <span class="text-sm text-gray-600 dark:text-gray-400">Available for new projects</span>
                </div>
                <p class="text-xs text-gray-400">Response time: Usually within 24 hours</p>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div data-animate>
            <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-4">Find Me Online</h3>
            <div class="grid grid-cols-2 gap-3">
              {socialLinks.filter(s => s.icon !== 'email').map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 p-3 rounded-xl bg-gray-50 dark:bg-white/5
                         border border-gray-100 dark:border-white/10
                         hover:border-brand-500/30 hover:bg-brand-50 dark:hover:bg-brand-950/30
                         transition-all duration-200 group text-sm font-medium
                         text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white"
                >
                  {social.icon === 'youtube' && (
                    <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                  )}
                  {social.icon === 'instagram' && (
                    <svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                  )}
                  {social.icon === 'linkedin' && (
                    <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  )}
                  {social.icon === 'whatsapp' && (
                    <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  )}
                  {social.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3" data-animate>
          <div class="glass-card">
            <h2 class="font-display font-bold text-2xl text-gray-900 dark:text-white mb-6">
              Send a Message
            </h2>

            <form
              id="contact-form"
              action="https://api.web3forms.com/submit"
              method="POST"
              class="space-y-5"
            >
              <!-- Web3Forms access key — replace with your own -->
              <input type="hidden" name="access_key" value="d89e4dac-994c-4604-95cb-f165e408adce" />
              <input type="hidden" name="subject" value="New message from smsaad.online" />
              <input type="hidden" name="redirect" value="https://smsaad.online/contact?success=true" />
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                    Your Name *
                  </label>
                  <input
                    id="name"
                    type="text"
                    name="name"
                    required
                    placeholder="John Smith"
                    class="input"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                    Email Address *
                  </label>
                  <input
                    id="email"
                    type="email"
                    name="email"
                    required
                    placeholder="john@example.com"
                    class="input"
                  />
                </div>
              </div>

              <div>
                <label for="service" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                  Service Needed
                </label>
                <select id="service" name="service" class="input">
                  <option value="">Select a service…</option>
                  <option>Podcast Video Editing</option>
                  <option>Short Form Reels</option>
                  <option>Captions & Subtitles</option>
                  <option>Audio Enhancement</option>
                  <option>Color Grading</option>
                  <option>Thumbnail Design</option>
                  <option>Other / Multiple</option>
                </select>
              </div>

              <div>
                <label for="budget" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                  Budget Range
                </label>
                <select id="budget" name="budget" class="input">
                  <option value="">Select budget…</option>
                  <option>Under $100</option>
                  <option>$100 – $500</option>
                  <option>$500 – $1,000</option>
                  <option>$1,000 – $5,000</option>
                  <option>$5,000+</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                  Project Details *
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Tell me about your project — what you need, your timeline, and any references or inspiration..."
                  class="input"
                ></textarea>
              </div>

              <!-- Success message -->
              <div id="form-success" class="hidden p-4 rounded-xl bg-green-50 dark:bg-green-950/30 text-green-700 dark:text-green-400 text-sm">
                ✅ Message sent! I'll get back to you within 24 hours.
              </div>

              <!-- Error message -->
              <div id="form-error" class="hidden p-4 rounded-xl bg-red-50 dark:bg-red-950/30 text-red-600 dark:text-red-400 text-sm">
                Something went wrong. Please try again or email me directly.
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="btn-primary w-full justify-center py-4 text-base"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Send Message
              </button>

              <p class="text-xs text-gray-400 text-center">
                By submitting, you agree that your data will be processed to respond to your inquiry.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Handle form submission success from URL param
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    document.getElementById('form-success')?.classList.remove('hidden');
  }

  // Client-side form handling with Web3Forms
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });

      if (response.ok) {
        document.getElementById('form-success')?.classList.remove('hidden');
        form.reset();
      } else {
        document.getElementById('form-error')?.classList.remove('hidden');
      }
    } catch {
      document.getElementById('form-error')?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
        Send Message
      `;
    }
  });
</script>
